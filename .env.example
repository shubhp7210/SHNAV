# Altos UTM — environment template.
# Copy this file to `.env` (or `.env.local`) and fill in real values.
# Never commit `.env` itself; it is gitignored.

# Supabase project — find these in your Supabase dashboard under Settings → API.
VITE_SUPABASE_PROJECT_ID="your-project-id"
VITE_SUPABASE_URL="https://your-project-id.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-publishable-key"

# Dev-only: set to "false" to enforce auth in `npm run dev` mode.
# In production builds the auth bypass is always disabled regardless of this value.
# VITE_BYPASS_AUTH="false"
